{
  "name": "ngiraud/laravel-starter",
  "description": "An opinionated starter to launch after creating a fresh Laravel application",
  "keywords": [
    "php",
    "laravel",
    "package",
    "starter",
    "laravel-starter"
  ],
  "homepage": "https://github.com/ngiraud/laravel-starter",
  "license": "MIT",
  "authors": [
    {
      "name": "Nicolas Giraud",
      "email": "contact@ngiraud.me",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "illuminate/contracts": "^12.0|^13.0",
    "laravel/prompts": "^0.3.6",
    "laravel/sail": "^1.44",
    "spatie/laravel-package-tools": "^1.16"
  },
  "require-dev": {
    "larastan/larastan": "^2.9||^3.0",
    "laravel/pint": "^1.14",
    "nunomaduro/collision": "^8.1.1||^7.10.0",
    "nunomaduro/pao": "^1.0",
    "orchestra/testbench": "^11.1.0",
    "pestphp/pest": "^4.0",
    "phpstan/extension-installer": "^1.3",
    "phpstan/phpstan-deprecation-rules": "^1.1||^2.0",
    "phpstan/phpstan-phpunit": "^1.3||^2.0",
    "phpunit/phpunit": "^12.5.20",
    "rector/rector": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "BerryValley\\LaravelStarter\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BerryValley\\LaravelStarter\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": "@composer run prepare",
    "prepare": "@php vendor/bin/testbench package:discover --ansi",
    "test": "vendor/bin/pest --parallel --compact",
    "test:lint": [
      "vendor/bin/pint --parallel --test",
      "vendor/bin/rector --dry-run"
    ],
    "test:types": "vendor/bin/phpstan analyse --memory-limit=-1",
    "test:all": [
      "@test:lint",
      "@test:types",
      "@test"
    ],
    "lint": "vendor/bin/pint --parallel",
    "refactor": "vendor/bin/rector"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "BerryValley\\LaravelStarter\\LaravelStarterServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
